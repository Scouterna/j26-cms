DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

SERVER_URL=http://localhost:3005
CORS_ORIGINS=http://localhost:3000

# Subpath the CMS is served under (empty when served at the domain root).
# Sets Next.js basePath (+ NEXT_PUBLIC_BASE_PATH). basePath is baked at build
# time — pass it as the NEXT_BASE_PATH build-arg for the Docker image; `pnpm dev`
# reads this .env value. When set, also include the subpath in SERVER_URL.
NEXT_BASE_PATH=

# Shared j26-auth service OIDC discovery endpoint (used to verify Keycloak tokens)
KEYCLOAK_DISCOVERY_URL=https://app.dev.j26.se/auth/.well-known/openid-configuration
